FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
        https://download.docker.com/linux/debian $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
        > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
        inotify-simple==1.3.5 \
        PyYAML==6.0.2

COPY supervisor/supervisor.py /opt/supervisor/supervisor.py
COPY supervisor/policy.yml /etc/supervisor/policy.yml

ENV PYTHONUNBUFFERED=1 \
    SUPERVISOR_SHARED_DIR=/shared \
    SUPERVISOR_POLICY_FILE=/etc/supervisor/policy.yml \
    SUPERVISOR_WORK_DIR=/work \
    MAX_CONCURRENT_SUBAGENTS=4 \
    SUPERVISOR_REQUIRE_APPROVAL=0 \
    SUPERVISOR_APPROVAL_TIMEOUT_SEC=60 \
    SUPERVISOR_POLL_MS=0

WORKDIR /opt/supervisor
ENTRYPOINT ["python", "/opt/supervisor/supervisor.py"]
